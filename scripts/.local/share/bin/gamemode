#!/usr/bin/env lua

package.path = os.getenv("HOME") .. "/.config/hypr/?.lua;" .. package.path

local gamemode = require("gamemode")

local command = arg[1]

if command == "enable" then
	gamemode.enable_gamemode()
elseif command == "disable" then
	gamemode.disable_gamemode()
elseif command == "toggle" then
	gamemode.toggle_gamemode()
	-- else
	-- 	io.stderr:write("Usage: gamemode {enable|disable|toggle}\n")
	-- 	os.exit(1)
end
