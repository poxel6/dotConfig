#!/usr/bin/env bash

echo "Removing orphan packages..."
echo "---------------------------"
sudo pacman -Rns $(yay -Qqdtt) --noconfirm

echo "Clearing caches"
echo "---------------------------"
sudo rm -rf /var/cache/pacman/pkg/*
sudo rm -rf $XDG_CACHE_HOME/yay/*
sudo rm -rf $XDG_CACHE_HOME/gradle/*
sudo rm -rf $XDG_CACHE_HOME/BraveSoftware/*
sudo rm -rf $XDG_CACHE_HOME/go/*
sudo rm -rf $HOME/.npm/_cacache/*

echo "Updating system..."
echo "---------------------------"
sudo pacman -Syu --noconfirm

# echo "Failed systemd services"
# echo "---------------------------"
# systemctl --failed | less
#
# echo "Journalctl logs"
# echo "---------------------------"
# journalctl -b

