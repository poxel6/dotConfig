CODEC=hevc_vaapi
FPS=60
MONITOR="DP-2"
AUDIO="alsa_output.pci-0000_00_1f.3.analog-stereo.monitor"
QP=20

TIME=$(date '+%Hh%Mm%Ss')
DATE=$(date '+%Y_%m_%d')
NAME=recording_$TIME
DIR=$HOME/Videos/recordings/$DATE

mkdir -p "$DIR"
echo $NAME

recording_base() {
	wf-recorder \
		-r "$FPS" \
		--codec "$CODEC" \
		-p qp=$QP \
		--force-yuv \
		--output "$MONITOR" \
		--audio "$AUDIO" \
		--file "$DIR/$NAME.mp4"
}

notification() {
	local app_name="Video Recording"
	local icon="audio-headphones-symbolic"
	local urgency="low"
	local title="Recording:"
	notify-send --app-name=$app_name --urgency=$urgency --icon=$icon "$@"
}

if pgrep -x "wf-recorder" >/dev/null; then
	notification "Recording Stopped"
	wf_pids=$(pgrep -x wf-recorder)
	if [ -n "$wf_pids" ]; then
		for pid in $wf_pids; do
			kill -15 $pid || true
		done
	fi
else
	notification "Recording Started"
	recording_base
fi
